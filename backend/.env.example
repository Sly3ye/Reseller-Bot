# Copia in backend/.env e compila con i valori reali.

# --- Supabase ---
SUPABASE_URL=
# Usa la SERVICE ROLE KEY: i motori di scraping scrivono bypassando la RLS.
SUPABASE_KEY=

# --- Proxy residenziale rotante IPRoyal ---
# Usato SOLO per le chiamate all'API hades.subito.it (ricerca/paginazione).
# Il download delle immagini dalla CDN va a connessione diretta (split routing).
# Lascia vuoto per andare in diretta anche sull'API.
PROXY_HOST=
PROXY_PORT=
PROXY_USER=
PROXY_PASS=

# --- Opzionali ---
# ENVIRONMENT=development
# CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
